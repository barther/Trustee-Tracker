{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/prototypes/*", "/preview.html", "/*.{css,js,jsx,svg,png,ico,jpg,webp,woff,woff2}"]
  },
  "mimeTypes": {
    ".json": "application/json",
    ".jsx": "application/javascript"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
